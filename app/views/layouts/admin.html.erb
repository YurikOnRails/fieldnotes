<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Admin — Fieldnotes" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "admin", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <nav class="admin-nav">
      <span class="admin-nav__title">Fieldnotes</span>
      <%= link_to "Essays", admin_essays_path %>
      <%= link_to "Builds", admin_builds_path %>
      <%= link_to "Books",  admin_books_path %>
      <%= link_to "Field",  admin_field_index_path %>
      <%= link_to "Now",    edit_admin_now_path %>
      <%= button_to "Sign out", session_path, method: :delete %>
    </nav>
    <main class="admin-main">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>
  </body>
</html>

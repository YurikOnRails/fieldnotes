<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title).present? ? "#{content_for(:title)} — Fieldnotes" : "Fieldnotes" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Fieldnotes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <% unless content_for?(:head) %>
      <%= meta_tags(title: "Fieldnotes", description: "Writing on software, technology, and building things.") %>
    <% end %>
    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "lexxy-content", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header class="site-header">
      <nav class="site-nav">
        <%= link_to "Fieldnotes", root_path, class: "site-nav-brand" %>
        <div class="site-nav-links">
          <%= link_to "Essays",  essays_path,      aria: { current: controller_path.end_with?("essays")  ? "page" : nil } %>
          <%= link_to "Builds",  builds_path,      aria: { current: controller_path.end_with?("builds")  ? "page" : nil } %>
          <%= link_to "Reading", books_path,       aria: { current: controller_path.end_with?("books")   ? "page" : nil } %>
          <%= link_to "Field",   field_index_path, aria: { current: controller_path.end_with?("field")   ? "page" : nil } %>
          <%= link_to "Now",     now_path,         aria: { current: controller_path.end_with?("now")     ? "page" : nil } %>
        </div>
      </nav>
    </header>

    <main class="site-main <%= content_for(:main_class) %>">
      <%= render "shared/flash" %>
      <%= yield %>
    </main>

    <footer class="site-footer">
      <nav class="site-footer-nav">
        <%= link_to "About",   about_path %>
        <%= link_to "Uses",    uses_path %>
        <%= link_to "Contact", contact_path %>
        <%= link_to "GitHub",  "https://github.com/YurikOnRails" %>
        <%= link_to "RSS",     feed_path(format: :rss) %>
      </nav>
    </footer>
  </body>
</html>

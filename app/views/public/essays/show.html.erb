<% content_for :title, @essay.title %>
<% content_for :head do %>
  <%= meta_tags(
    title:        @essay.title,
    description:  @essay.excerpt.presence || @essay.title,
    image:        @essay.cover.attached? ? url_for(@essay.cover) : nil,
    type:         :article,
    published_at: @essay.published_at
  ) %>
<% end %>

<article>
  <h1><%= @essay.title %></h1>
  <time datetime="<%= @essay.published_at.iso8601 %>"><%= @essay.published_at.strftime("%B %d, %Y") %></time>
  <% if @essay.location_name.present? %>
    <p><%= @essay.location_name %></p>
  <% end %>
  <div class="essay-content lexxy-content">
    <%= @essay.content %>
  </div>
</article>

<% content_for :title, @essay.title %>
<% content_for :main_class, "site-main--essay" %>
<% content_for :head do %>
  <%= meta_tags(
    title:        @essay.title,
    description:  @essay.excerpt.presence || @essay.title,
    image:        @essay.cover.attached? ? url_for(@essay.cover) : nil,
    type:         :article,
    published_at: @essay.published_at
  ) %>
<% end %>

<div class="essay-layout" data-controller="toc">
  <article class="essay-article" data-toc-target="content">
    <h1><%= @essay.title %></h1>
    <div class="essay-meta">
      <time datetime="<%= @essay.published_at.iso8601 %>"><%= @essay.published_at.strftime("%B %d, %Y") %></time>
      <% if @essay.location_name.present? %>
        <span>·</span>
        <span><%= @essay.location_name %></span>
      <% end %>
    </div>
    <div class="essay-content lexxy-content">
      <%= @essay.content %>
    </div>
  </article>

  <aside class="essay-toc" data-toc-target="nav" aria-label="Table of contents">
    <p class="essay-toc__title">Contents</p>
  </aside>
</div>

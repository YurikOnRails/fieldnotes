<% content_for :title, @book.title %>
<% content_for :head do %>
  <%= meta_tags(
    title: "#{@book.title} — #{@book.author}",
    description: @book.key_idea.to_s.truncate(160),
    image: @book.cover_image_url
  ) %>
<% end %>

<div class="book-show">
  <div class="book-show__cover">
    <% if @book.cover_image_url.present? %>
      <img src="<%= @book.cover_image_url %>" alt="<%= @book.title %>">
    <% else %>
      <div class="book-card__placeholder">
        <span><%= @book.title %></span>
      </div>
    <% end %>
  </div>

  <div class="book-show__content">
    <header class="book-show__header">
      <h1><%= @book.title %></h1>
      <p class="book-show__author"><%= @book.author %></p>

      <div class="book-show__meta">
        <% if @book.rating %>
          <span class="book-show__rating"><%= "★" * @book.rating %><%= "☆" * (5 - @book.rating) %></span>
        <% end %>
        <span class="book-show__status badge badge--<%= @book.status %>"><%= @book.status %></span>
        <% if @book.year_read %>
          <span class="book-show__year">Read in <%= @book.year_read %></span>
        <% end %>
      </div>
    </header>

    <% if @book.key_idea.present? %>
      <section class="book-show__section">
        <h2>Key idea</h2>
        <p><%= @book.key_idea %></p>
      </section>
    <% end %>

    <% if @book.review.present? %>
      <section class="book-show__section">
        <h2>Notes & review</h2>
        <div class="lexxy-content">
          <%= @book.review %>
        </div>
      </section>
    <% end %>

    <p class="book-show__back"><%= link_to "← Back to reading list", books_path %></p>
  </div>
</div>

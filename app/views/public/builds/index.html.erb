<% content_for :title, "Builds" %>
<% content_for :head do %>
  <%= meta_tags(title: "Builds", description: "Projects, businesses, and things I've built.") %>
<% end %>

<%= render "shared/profile_hero", profile: @profile %>

<h1>Builds</h1>
<div class="builds-grid">
  <% @builds.each do |build| %>
    <%= render "shared/build_card", build: build %>
  <% end %>
</div>

<div class="admin-toolbar">
  <h1>Profile</h1>
</div>

<%= form_with model: @profile, url: admin_profile_path, method: :patch do |f| %>
  <% if @profile.errors.any? %>
    <div class="error-list">
      <% @profile.errors.each do |e| %><p><%= e.full_message %></p><% end %>
    </div>
  <% end %>

  <div class="admin-card">
    <div class="field">
      <%= f.label :name, "Name" %>
      <%= f.text_field :name %>
    </div>

    <div class="field">
      <%= f.label :bio, "Bio" %>
      <%= f.rich_text_area :bio %>
    </div>

    <div class="field">
      <%= f.label :avatar, "Avatar" %>
      <%= f.file_field :avatar, accept: "image/*" %>
      <% if @profile.avatar.attached? %>
        <p class="field-hint">Current: <%= @profile.avatar.filename %> — upload a new file to replace</p>
        <%= image_tag @profile.avatar, alt: "Avatar", class: "avatar-preview" %>
      <% end %>
    </div>
  </div>

  <%= f.submit "Save", class: "btn btn--primary" %>
<% end %>

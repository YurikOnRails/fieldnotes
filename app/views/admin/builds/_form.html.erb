<%= form_with model: [:admin, build] do |f| %>
  <% if build.errors.any? %>
    <div class="error-list">
      <% build.errors.each do |e| %><p><%= e.full_message %></p><% end %>
    </div>
  <% end %>

  <div class="admin-card">
    <div class="field"><%= f.label :title %><%= f.text_field :title %></div>
    <div class="field"><%= f.label :slug %><%= f.text_field :slug %></div>
    <div class="field"><%= f.label :description %><%= f.text_area :description, rows: 3 %></div>
    <div class="field"><%= f.label :url %><%= f.url_field :url %></div>
    <div class="field"><%= f.label :icon_emoji %><%= f.text_field :icon_emoji %></div>
    <div class="field"><%= f.label :status %><%= f.select :status, Build::STATUSES %></div>
    <div class="field"><%= f.label :kind %><%= f.select :kind, Build::KINDS %></div>
    <div class="field"><%= f.label :position %><%= f.number_field :position %></div>
    <div class="field"><%= f.label :started_on %><%= f.date_field :started_on %></div>
    <div class="field"><%= f.label :finished_on %><%= f.date_field :finished_on %></div>
  </div>

  <%= f.submit class: "btn btn--primary" %>
<% end %>

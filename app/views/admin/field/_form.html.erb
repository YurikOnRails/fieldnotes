<%= form_with model: [:admin, series], url: series.new_record? ? admin_field_index_path : admin_field_path(series) do |f| %>
  <% if series.errors.any? %>
    <div class="error-list">
      <% series.errors.each do |e| %><p><%= e.full_message %></p><% end %>
    </div>
  <% end %>

  <div class="admin-card">
    <div class="field"><%= f.label :title %><%= f.text_field :title %></div>
    <div class="field"><%= f.label :description %><%= f.text_area :description, rows: 3 %></div>
    <div class="field"><%= f.label :kind %><%= f.select :kind, FieldSeries::KINDS %></div>
    <div class="field"><%= f.label :location %><%= f.text_field :location %></div>
    <div class="field"><%= f.label :taken_on %><%= f.date_field :taken_on %></div>
  </div>

  <%= f.submit class: "btn btn--primary" %>
<% end %>

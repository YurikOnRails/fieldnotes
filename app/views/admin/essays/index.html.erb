<div class="admin-toolbar">
  <h1>Essays</h1>
  <%= link_to "New Essay", new_admin_essay_path, class: "btn btn--primary" %>
</div>

<% if @essays.any? %>
  <table class="admin-table">
    <thead>
      <tr>
        <th>Title</th>
        <th>Status</th>
        <th>Published</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @essays.each do |essay| %>
        <tr>
          <td><%= link_to essay.title, edit_admin_essay_path(essay) %></td>
          <td><span class="badge badge--<%= essay.status %>"><%= essay.status %></span></td>
          <td><%= essay.published_at&.strftime("%b %d, %Y") %></td>
          <td class="actions">
            <% if essay.published? %>
              <%= link_to "View", essay_path(essay.slug), target: "_blank" %>
            <% end %>
            <%= button_to "Delete", admin_essay_path(essay), method: :delete, form: { data: { turbo_confirm: "Delete «#{essay.title}»?" } }, class: "btn btn--danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="admin-empty">No essays yet. <%= link_to "Write your first one", new_admin_essay_path %>.</p>
<% end %>

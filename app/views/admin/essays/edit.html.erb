<div class="admin-toolbar">
  <h1>Edit Essay</h1>
  <% if @essay.published? %>
    <%= link_to "View on site", essay_path(@essay.slug), target: "_blank", class: "btn btn--secondary" %>
  <% end %>
</div>
<%= render "form", essay: @essay %>

<hr class="admin-section-sep">
<div class="danger-zone">
  <p class="danger-zone__label">Danger Zone</p>
  <%= button_to "Delete Essay", admin_essay_path(@essay), method: :delete,
        form: { data: { turbo_confirm: "Delete «#{@essay.title}»?" } },
        class: "btn btn--danger btn--small" %>
</div>

<%= form_with model: [:admin, essay] do |f| %>
  <% if essay.errors.any? %>
    <div class="error-list">
      <% essay.errors.each do |e| %><p><%= e.full_message %></p><% end %>
    </div>
  <% end %>

  <div class="admin-card">
    <div class="field"><%= f.label :title %><%= f.text_field :title %></div>
    <div class="field"><%= f.label :excerpt %><%= f.text_area :excerpt, rows: 3 %></div>
    <div class="field"><%= f.label :status %><%= f.select :status, Essay::STATUSES %></div>
    <div class="field">
      <%= f.label :published_at %>
      <%= f.datetime_local_field :published_at %>
      <p class="field-hint">Leave blank — will be set automatically when published.</p>
    </div>
    <div class="field"><%= f.label :location_name %><%= f.text_field :location_name %></div>
    <div class="field"><%= f.label :cover %><%= f.file_field :cover %></div>
  </div>

  <div class="admin-card">
    <div class="field"><%= f.label :content %><%= f.rich_text_area :content %></div>
  </div>

  <%= f.submit class: "btn btn--primary" %>
<% end %>

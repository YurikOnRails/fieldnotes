<div class="admin-toolbar">
  <h1>Books</h1>
  <%= link_to "New Book", new_admin_book_path, class: "btn btn--primary" %>
</div>

<table class="admin-table">
  <thead>
    <tr><th>Title</th><th>Author</th><th>Status</th><th>Rating</th><th></th></tr>
  </thead>
  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= link_to book.title, admin_book_path(book) %></td>
        <td><%= book.author %></td>
        <td><span class="badge badge--<%= book.status %>"><%= book.status %></span></td>
        <td><%= book.rating ? "★" * book.rating : "—" %></td>
        <td class="actions">
          <%= link_to "Edit", edit_admin_book_path(book) %>
          <%= button_to "Delete", admin_book_path(book), method: :delete, form: { data: { turbo_confirm: "Delete «#{book.title}»?" } }, class: "btn btn--danger" %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

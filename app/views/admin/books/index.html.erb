<div class="admin-toolbar">
  <h1>Books</h1>
  <%= link_to "New Book", new_admin_book_path, class: "btn btn--primary" %>
</div>

<% if @books.any? %>
  <table class="admin-table">
    <thead>
      <tr><th>Title</th><th>Author</th><th>Status</th><th>Rating</th><th></th></tr>
    </thead>
    <tbody>
      <% @books.each do |book| %>
        <tr>
          <td><%= link_to book.title, edit_admin_book_path(book) %></td>
          <td><%= book.author %></td>
          <td><span class="badge badge--<%= book.status %>"><%= book.status %></span></td>
          <td><%= book.rating ? "★" * book.rating : "—" %></td>
          <td class="actions"></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p class="admin-empty">No books yet. <%= link_to "Add your first one", new_admin_book_path %>.</p>
<% end %>

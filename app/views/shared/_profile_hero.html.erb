<section class="profile-hero">
  <div class="profile-hero__avatar">
    <% if profile.avatar.attached? %>
      <%= image_tag profile.avatar, alt: profile.name, width: 96, height: 96 %>
    <% else %>
      <img src="/avatar.jpg" alt="<%= profile.name %>" width="96" height="96">
    <% end %>
  </div>
  <div class="profile-hero__body">
    <h2 class="profile-hero__name"><%= profile.name %></h2>
    <% if profile.bio.present? %>
      <div class="profile-hero__bio lexxy-content"><%= profile.bio %></div>
    <% end %>
  </div>
</section>
